rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Users — each user can read and write only their own document
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // -----------------------------------------------------------------------
    // Comics — public read; write restricted to admin claims
    // TODO: tighten this before production by removing the broad write rule
    //       and relying on a Firebase Admin SDK publishing flow or a custom
    //       admin claim: request.auth.token.admin == true
    // -----------------------------------------------------------------------
    match /comics/{comicId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;

      // Chapters nested under each comic
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.admin == true;
      }
    }
  }
}
